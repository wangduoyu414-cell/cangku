# CreatorOS 环境变量模板
# 复制为 .env 后填写实际值

# ===== 浏览器引擎 =====
BROWSER_HEADLESS=true
PLAYWRIGHT_BROWSERS_PATH=./playwright-browsers

# ===== 代理配置 =====
# 移动 4G 代理（逗号分隔，多个自动轮换）
PROXY_MOBILE=
# 住宅代理
PROXY_RESIDENTIAL=
# 代理认证（格式: user:pass@host:port）
PROXY_AUTH=

# ===== 接码平台 =====
# ZSMS
ZSMS_API_KEY=
ZSMS_API_URL=https://api.zsms.pro

# OSMS
OSMS_API_KEY=
OSMS_API_URL=https://api.osms.pro

# HSMS
HSMS_API_KEY=
HSMS_API_URL=https://api.hsms.pro

# ===== 云手机（原生 App 模式） =====
# VMOSCloud
VMOS_API_KEY=
VMOS_API_URL=https://api.vmosc.com

# DuoPlus
DUOPLUS_API_KEY=
DUOPLUS_API_URL=https://api.duoplus.me

# ===== 数据库（可选） =====
# PostgreSQL（账号元数据存储）
DATABASE_URL=

# Redis（任务队列）
REDIS_URL=redis://localhost:6379

# ===== AI Provider（创作者经济层） =====
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ===== MCP Server =====
MCP_PORT=3001
MCP_HOST=0.0.0.0

# ===== REST API =====
API_PORT=3000
API_HOST=0.0.0.0
API_KEY=

# ===== 监控 =====
SENTRY_DSN=
