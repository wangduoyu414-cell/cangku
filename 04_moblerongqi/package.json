{
  "name": "creator-os",
  "version": "0.1.0",
  "description": "CreatorOS Cloud Mobile Simulation Container Platform",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node build.mjs",
    "dev": "node --watch packages/*/src/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages --ext .ts,.tsx,.js,.jsx",
    "typecheck": "tsc --noEmit --incremental",
    "clean": "rm -rf packages/*/dist packages/*/.tsbuildinfo"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.12.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "patchright": "^1.59.4",
    "tesseract.js": "^5.0.0",
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
